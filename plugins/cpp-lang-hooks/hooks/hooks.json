{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/post_edit_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running C++ format and tidy checks"
          }
        ],
        "description": "Run clang-format and clang-tidy on modified C/C++ files after edits",
        "id": "cpp-lang-hooks:post-edit-clang-format"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/stop_hook.mjs\"",
            "timeout": 180,
            "statusMessage": "Running C++ test checks"
          }
        ],
        "description": "Run ctest for the current CMake project when available",
        "id": "cpp-lang-hooks:stop-checks"
      }
    ]
  }
}
